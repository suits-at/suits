---
import BrandIcon from '@/components/BrandIcon.astro';
import { socialLinks } from '@/data/social';
---

<footer class="site-footer">
  <div
    class="container flex flex-col items-center gap-5 py-6 text-center sm:grid sm:grid-cols-3"
  >
    <a href="mailto:office@suits.at">office@suits.at</a>

    <div class="flex items-center justify-center gap-7">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            title={link.label}
            target="_blank"
            rel="noopener"
            aria-label={link.label}
          >
            <BrandIcon
              name={link.icon}
              label={link.label}
              class="h-8 w-8 transition-transform duration-200 hover:scale-110"
            />
          </a>
        ))
      }
    </div>

    <a href="/impressum/">Impressum</a>
  </div>
</footer>
